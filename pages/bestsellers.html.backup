            </button>
          </div>
        </div>
        <div class="product-info">
          <p class="product-series">Code DRYN 6357</p>
          <p class="product-name">Seemivest Bordir Flow Dress</p>
        </div>
      </div>
      <!-- Card 4 -->
      <div class="product-card reveal" style="transition-delay:0.3s">
        <div class="product-img-wrap" style="cursor:pointer;" onclick="openProductDetail('prod_3'); return false;">
          <img class="img-main" loading="lazy" src="images/img-7.jpeg" alt="TNVX 8307 3 Pocky Top" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center top;">
          <img class="img-hover" loading="lazy" src="images/img-8.jpeg" alt="TNVX 8307 3 Pocky Top hover" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center top;">
          <div class="product-actions">
            <button class="product-action-btn wishlist-btn" aria-label="Add to wishlist" data-id="prod_3" data-name="3 Pocky Top" data-series="Code TNVX 8307" data-price="—" onclick="toggleWishlist(this)">
              <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
