            <button class="product-action-btn wishlist-btn" aria-label="Add to wishlist" data-id="prod_2" data-name="Seemivest Bordir Flow Dress" data-series="Code DRYN 6357" data-price="—" onclick="toggleWishlist(this)">
              <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
