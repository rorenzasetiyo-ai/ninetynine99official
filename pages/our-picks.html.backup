      <!-- Pick 1 -->
      <div class="product-card reveal">
        <div class="product-img-wrap" style="cursor:pointer;" onclick="openProductDetail('prod_4'); return false;">
          <img class="img-main" loading="lazy" src="images/img-10.jpeg" alt="Flowcolour Cream Blouse" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center top;">
          <img class="img-hover" loading="lazy" src="images/img-11.jpeg" alt="Flowcolour Cream Blouse hover" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center top;">
          <div class="product-actions">
            <button class="product-action-btn wishlist-btn" aria-label="Add to wishlist" data-id="prod_4" data-name="Flowcolour Cream Blouse" data-series="Code TPSHRL 9157" data-price="IDR 128.000" onclick="toggleWishlist(this)">
              <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </button>
            <button class="product-action-btn" aria-label="Add to cart" onclick="quickAddToCart('prod_4'); return false;">
              <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
